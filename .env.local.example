ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL=postgres://app:app@localhost:5432/labels
# PGSSLMODE=require              # set when your managed Postgres requires TLS
# MODEL=claude-sonnet-4-6        # optional model overrides
# LABEL_MODEL=claude-haiku-4-5
# FORM_MODEL=claude-sonnet-4-6
# BATCH_CONCURRENCY=6            # optional concurrency override

# ── Optional: DB TLS ───────────────────────────────────────────────
# PGSSLROOTCERT=/path/to/ca.pem            # CA bundle to validate the DB server cert (no default)
# ── Optional: latency display target ───────────────────────────────
# LATENCY_TARGET_MS=5000                   # per-label target the UI flags against (no verdict effect)
# ── Optional: upload guards (bytes) ────────────────────────────────
# UPLOAD_MAX_BYTES=268435456               # max request body before buffering (256 MiB)
# VERIFY_MAX_FILE_BYTES=52428800           # per-file cap on the upload tab (50 MiB)
# VERIFY_MAX_ITEMS=500                     # max applications per /api/verify request
# CSV_MAX_BYTES=16777216                   # max CSV file size (16 MiB)
# CSV_MAX_ROWS=5000                        # max CSV data rows per file
# ── Optional: CSV label-image caps ─────────────────────────────────
# CSV_IMAGE_MAX_BYTES=12582912             # per-image / per-ZIP-entry cap (12 MiB)
# CSV_MAX_IMAGES_PER_ROW=6                 # max images referenced per CSV row
# CSV_IMAGE_ZIP_MAX_BYTES=104857600        # uploaded image-ZIP, compressed (100 MiB)
# CSV_IMAGE_ZIP_MAX_TOTAL_BYTES=209715200  # decompressed budget — zip-bomb guard (200 MiB)
# ── Optional: upload-tab ZIP of PDFs/images ────────────────────────
# PDF_ZIP_MAX_BYTES=209715200              # dropped PDF-ZIP, compressed (200 MiB)
# PDF_ZIP_MAX_ENTRY_BYTES=52428800         # max decompressed size of one entry (50 MiB)
# PDF_ZIP_MAX_TOTAL_BYTES=524288000        # max total decompressed from one ZIP (500 MiB)
