node_modules
.next
.env*.local
*.tsbuildinfo
next-env.d.ts
context/
# LibreOffice/OpenOffice lock files
.~lock.*#
# Local sample inputs are versioned via Git LFS (see .gitattributes). Lone
# exception: the 163 MB source PDF archive stays out of git entirely.
test-form-pdfs/*.zip
# Unzipped CSV label images — the .zip is the canonical artifact (LFS); these
# loose files are local-only, kept out so a stray `git add -A` can't commit them.
test-csvs/img/

# Local self-signed dev TLS cert (for --experimental-https on machines where
# mkcert's CA install is blocked) — never commit the private key.
certificates/
